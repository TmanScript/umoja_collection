# ─────────────────────────────────────────────────────────────────────────────
# Environment template. Copy this file to ".env" and fill in real values:
#     cp .env.example .env
#
# All VITE_* variables are exposed to the browser bundle (see README.md).
# Never put a true server-side secret here without a backend proxy in front.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase key. Use the public "anon" key (NOT the service_role key) together
# with Row Level Security policies on every table.
VITE_SUPABASE_KEY=your-supabase-anon-key

# Umoja Portal API
VITE_UMOJA_API_BASE_URL=https://portal.umoja.network/api/2.0/admin
VITE_UMOJA_DEFAULT_TOKEN=your-umoja-basic-auth-token
VITE_UMOJA_SALES_TOKEN=your-umoja-sales-reporting-token
